#include<reg51.h>
sbit rs=P1^0;
sbit rw=P1^1;
sbit en=P1^2;
void lcdcmd(char com);
void lcddat(char dat);
void delay();
void main()
	{
		P2=0X00;
		while(1)
		{
lcdcmd(0x38);
delay();
lcdcmd(0x01);
delay();
lcdcmd(0x06);
delay();
lcdcmd(0x0c);
delay();
lcdcmd(0x80);
delay();
lcddat('s');
delay();
lcddat('e');
delay();
lcddat('n');
delay();
lcddat('t');
delay();
lcddat('h');
delay();
lcddat('i');
delay();
lcddat('l');
delay();
}
}
void lcdcmd(char com)
{
P2=com;
rs=0;
rw=0;
en=1;
delay();
en=0;
}
void lcddat(char dat)
{
P2=dat;
rs=1;
rw=0;
en=1;
delay();
en=0;
}	
void delay()
{
unsigned int i;
	
for(i=0;i<10000;i++);
}
