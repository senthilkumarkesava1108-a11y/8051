#include <reg51.h>

void delay(unsigned int);

void display(unsigned int digit)
{
	switch(digit)
	{
		case 0:
			P2=0XC0;
		break;
		case 1:
		P2=0xf9;
		break;
		case 2:
		P2=0xa4;
		break;
		case 3:
		P2=0xb0;
		break;
		case 4:
		P2=0x99;
		break;
		case 5:
		P2=0x92;
		break;
		case 6:
			P2=0x82;
		break;
		case 7:
			P2=0xf8;
		break;
		case 8:
			P2=0x80;
		break;
		case 9:
			P2=0x90;
		break;
		default:
			P2=0xff;
		break;
	}
}
void main(){
	unsigned char i;
	
	while(1){
		for(i=0;i<=9;i++){
			display(i);
			delay(1000);
		}
	}
}
	void delay(unsigned int ms)
		{
			int i, j;
			for(i=0;i<ms;i++)
			for(j=0;j<100;j++);
		}
		
		
   
	
